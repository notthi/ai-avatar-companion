# このファイルをコピーして .env を作成し、値を埋めてください( copy .env.example .env )
# .env は .gitignore 済みなので、実トークンはコミットされません。

# ===== 接続先エージェント =====
# hermes = Hermes Agent (NousResearch) / openclaw = OpenClaw
GATEWAY_KIND=hermes

# Hermes AgentのAPIサーバー。Hermes側で API_SERVER_ENABLED=true が必要。
# ポートはHermes側の API_SERVER_PORT に合わせる(デフォルト 8643)
GATEWAY_URL=http://127.0.0.1:8643
# Hermes側の API_SERVER_KEY と同じ値
GATEWAY_TOKEN=PASTE_YOUR_HERMES_API_SERVER_KEY_HERE
# 会話文脈の識別子(任意の名前でOK。Discord等とは別のセッションになる)
SESSION_KEY=voice-assistant

# --- OpenClawに戻す場合の例 ---
# GATEWAY_KIND=openclaw
# GATEWAY_URL=http://127.0.0.1:18789
# GATEWAY_TOKEN=（OpenClawのgateway token）
# OPENCLAW_AGENT_ID=main
# SESSION_KEY=agent:line:main

# ===== server.js の待受ポート =====
PORT=8787

# ===== VOICEVOX(server.js と同じPCで起動していること)。8 = 春日部つむぎ =====
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=8
VOICEVOX_SPEED=1.1
